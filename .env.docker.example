# MongoDB Credentials for Docker Compose
# These are used by docker-compose.yml to set up MongoDB and connect backends
MONGO_USERNAME=admin
MONGO_PASSWORD=change_this_strong_password_in_production

# Socket.IO CORS Origins (comma-separated, no spaces)
# For development, you can use specific origins or "*" for all
# For production, specify exact frontend URLs
SOCKET_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Note: Other environment variables should be set in the main .env file
# This file is specifically for Docker Compose environment variables
